generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  GUEST
  USER
  ADMIN
}

enum EventStatus {
  DRAFT
  SCHEDULED
  OPEN
  CLOSED
  SETTLED
  CANCELED
}

enum MarketType {
  WINNER
  OVER_UNDER
  YES_NO
  CUSTOM
}

enum MarketStatus {
  OPEN
  LOCKED
  SETTLED
  CANCELED
}

enum OutcomeResult {
  PENDING
  WON
  LOST
  VOID
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

enum TransactionType {
  INITIAL_ALLOCATION
  BET_PLACED
  BET_WON
  BET_VOID
  DAILY_BONUS
  CHALLENGE_REWARD
  ADMIN_ADJUSTMENT
}

enum ReferenceType {
  BET
  EVENT
  USER
  SYSTEM
}

enum OddsChangeTrigger {
  BET_PLACED
  ADMIN_CHANGE
  RECALCULATION
  DAILY_CRON
}

enum Visibility {
  PUBLIC
  RESTRICTED
}

enum NotificationType {
  USER_REGISTERED
  BET_PLACED
  EVENT_CREATED
  EVENT_SETTLED
  SYSTEM
  PROFILE_CHANGE_REQUESTED
}

enum ProfileChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         Role      @default(USER)
  tokenBalance Decimal   @default(0) @map("token_balance") @db.Decimal(19, 4)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  bio          String?   @db.VarChar(500)
  locale       String?   @default("de") @db.VarChar(5)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  settings     Json?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()
  version      BigInt    @default(0)

  bets                Bet[]
  events              Event[]
  tokenTransactions   TokenTransaction[] @relation("UserTransactions")
  createdTransactions TokenTransaction[] @relation("TransactionCreator")
  oddsHistory         OddsHistory[]
  adminAuditLogs      AdminAuditLog[]
  notifications       Notification[]
  pendingProfileChanges  PendingProfileChange[] @relation("ProfileChanges")
  reviewedProfileChanges PendingProfileChange[] @relation("ProfileChangeReviewer")

  @@index([username])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id            Int     @id @default(autoincrement())
  name          String  @db.VarChar(100)
  nameEn        String? @map("name_en") @db.VarChar(100)
  slug          String  @unique @db.VarChar(100)
  description   String? @db.VarChar(500)
  descriptionEn String? @map("description_en") @db.VarChar(500)
  iconName      String? @map("icon_name") @db.VarChar(50)
  sortOrder     Int     @default(0) @map("sort_order")

  events Event[]

  @@map("categories")
}

model Event {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String      @db.VarChar(255)
  titleEn       String?     @map("title_en") @db.VarChar(255)
  description   String?
  descriptionEn String?     @map("description_en")
  categoryId    Int?        @map("category_id")
  status        EventStatus @default(DRAFT)
  startTime     DateTime?   @map("start_time") @db.Timestamptz()
  endTime       DateTime?   @map("end_time") @db.Timestamptz()
  imageUrl      String?     @map("image_url") @db.VarChar(500)
  isFeatured    Boolean     @default(false) @map("is_featured")
  visibility    Visibility  @default(PUBLIC)
  createdById   String?     @map("created_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz()

  category  Category? @relation(fields: [categoryId], references: [id])
  createdBy User?     @relation(fields: [createdById], references: [id])
  markets   Market[]

  @@index([status])
  @@index([categoryId])
  @@map("events")
}

model Market {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId      String       @map("event_id") @db.Uuid
  name         String       @db.VarChar(255)
  nameEn       String?      @map("name_en") @db.VarChar(255)
  type         MarketType
  status       MarketStatus @default(OPEN)
  marginFactor     Decimal      @default(0.9500) @map("margin_factor") @db.Decimal(5, 4)
  virtualPool      Decimal      @default(100) @map("virtual_pool") @db.Decimal(19, 4)
  oddsScaleFactor  Decimal      @default(1) @map("odds_scale_factor") @db.Decimal(10, 4)
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  outcomes Outcome[]

  @@index([eventId])
  @@index([status])
  @@map("markets")
}

model Outcome {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marketId     String        @map("market_id") @db.Uuid
  name         String        @db.VarChar(255)
  nameEn       String?       @map("name_en") @db.VarChar(255)
  initialOdds   Decimal       @map("initial_odds") @db.Decimal(10, 4)
  currentOdds   Decimal       @map("current_odds") @db.Decimal(10, 4)
  totalStaked   Decimal       @default(0) @map("total_staked") @db.Decimal(19, 4)
  virtualStaked Decimal       @default(0) @map("virtual_staked") @db.Decimal(19, 4)
  logWeightSum  Decimal       @default(0) @map("log_weight_sum") @db.Decimal(19, 4)
  betCount      Int           @default(0) @map("bet_count")
  resultStatus  OutcomeResult @default(PENDING) @map("result_status")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  market      Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  bets        Bet[]
  oddsHistory OddsHistory[]

  @@index([marketId])
  @@index([resultStatus])
  @@map("outcomes")
}

model Bet {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  outcomeId       String    @map("outcome_id") @db.Uuid
  stake           Decimal   @db.Decimal(19, 4)
  oddsAtPlacement Decimal   @map("odds_at_placement") @db.Decimal(10, 4)
  potentialWin    Decimal   @map("potential_win") @db.Decimal(19, 4)
  status          BetStatus @default(PENDING)
  settledAt       DateTime? @map("settled_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user    User    @relation(fields: [userId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@index([userId])
  @@index([outcomeId])
  @@index([status])
  @@index([userId, status])
  @@map("bets")
}

model TokenTransaction {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(19, 4)
  balanceAfter  Decimal         @map("balance_after") @db.Decimal(19, 4)
  referenceType ReferenceType?  @map("reference_type")
  referenceId   String?         @map("reference_id") @db.Uuid
  description   String?         @db.VarChar(500)
  createdById   String?         @map("created_by") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  user      User  @relation("UserTransactions", fields: [userId], references: [id])
  createdBy User? @relation("TransactionCreator", fields: [createdById], references: [id])

  @@index([userId])
  @@index([type])
  @@index([userId, createdAt(sort: Desc)])
  @@map("token_transactions")
}

model OddsHistory {
  id          Int               @id @default(autoincrement())
  outcomeId   String            @map("outcome_id") @db.Uuid
  oldOdds     Decimal           @map("old_odds") @db.Decimal(10, 4)
  newOdds     Decimal           @map("new_odds") @db.Decimal(10, 4)
  triggerType OddsChangeTrigger @map("trigger")
  changedById String?           @map("changed_by") @db.Uuid
  changedAt   DateTime          @default(now()) @map("changed_at") @db.Timestamptz()

  outcome   Outcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id])

  @@index([outcomeId])
  @@index([changedAt(sort: Desc)])
  @@map("odds_history")
}

model AdminAuditLog {
  id         Int      @id @default(autoincrement())
  adminId    String   @map("admin_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
  @@map("admin_audit_log")
}

model SystemSetting {
  key         String    @id @db.VarChar(100)
  value       String    @db.VarChar(255)
  description String?   @db.VarChar(500)
  dataType    String?   @map("data_type") @db.VarChar(20)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  updatedBy   String?   @map("updated_by") @db.Uuid

  @@map("system_settings")
}

model Notification {
  id         Int              @id @default(autoincrement())
  type       NotificationType
  title      String           @db.VarChar(255)
  message    String           @db.VarChar(500)
  entityType String?          @map("entity_type") @db.VarChar(50)
  entityId   String?          @map("entity_id") @db.Uuid
  isRead     Boolean          @default(false) @map("is_read")
  adminId    String?          @map("admin_id") @db.Uuid
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  admin User? @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model PendingProfileChange {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  changes    Json
  status     ProfileChangeStatus @default(PENDING)
  reviewedBy String?             @map("reviewed_by") @db.Uuid
  reviewedAt DateTime?           @map("reviewed_at") @db.Timestamptz()
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  user     User  @relation("ProfileChanges", fields: [userId], references: [id])
  reviewer User? @relation("ProfileChangeReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([userId])
  @@map("pending_profile_changes")
}
